<!-- Opening Animation Overlay -->
<div class="splash-screen" id="splashScreen">
    <div class="splash-content">
        <h1 class="splash-text">Hi I am Karthik</h1>
    </div>
</div>

<script>
    // Check if the user just refreshed the page
    const navEntries = performance.getEntriesByType("navigation");
    const isReload = navEntries.length > 0 && navEntries[0].type === "reload";

    if (!sessionStorage.getItem('splashShown') || isReload) {
        // First time visit or refresh: play the animation
        sessionStorage.setItem('splashShown', 'true');
    } else {
        // Navigating via links: hide the splash screen immediately
        const splash = document.getElementById('splashScreen');
        if (splash) splash.style.display = 'none';
        document.body.style.animation = 'none';
        document.body.style.overflow = 'visible';
    }
</script>

